# Database
DATABASE_URL="postgresql://edushare:edushare_pass@localhost:5432/edushare_db"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EduShare"

# File Upload (local storage by default)
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE=10485760

# Cloudinary (required for ID card and note uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional: AWS S3 (comment out UPLOAD_DIR if using S3)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="ap-south-1"
# AWS_S3_BUCKET=""
